# =============================================================================
# Oura Ring API Sandbox -- Environment Configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# --- Oura OAuth2 Credentials ---
# Register at https://developer.ouraring.com/applications
OURA_CLIENT_ID=your_client_id_here
OURA_CLIENT_SECRET=your_client_secret_here
OURA_REDIRECT_URI=http://localhost:8501/

# Tokens (populated automatically after OAuth2 flow)
OURA_ACCESS_TOKEN=
OURA_REFRESH_TOKEN=

# --- Oura API (advanced, usually not needed) ---
# OURA_AUTHORIZE_URL=https://cloud.ouraring.com/oauth/authorize
# OURA_TOKEN_URL=https://api.ouraring.com/oauth/token
# OURA_API_BASE_URL=https://api.ouraring.com
# API_TIMEOUT=30.0
# API_MAX_RETRIES=3

# --- User Data (Phase 4: Excel, PDF imports) ---
# Directory for imported health data. Must be in .gitignore. Default: data/
# DATA_DIR=data

# --- Dashboard Settings ---
# CACHE_TTL_SECONDS=300
# DEFAULT_DATE_RANGE_DAYS=30
# CHART_TEMPLATE=plotly_dark

# --- Sleep Analyzer Thresholds ---
# SLEEP_EFFICIENCY_GOOD=85
# SLEEP_EFFICIENCY_FLAG=80
# SLEEP_LATENCY_FLAG_MIN=30

# --- Anomaly Detection ---
# ANOMALY_WINDOW_DAYS=14
# ANOMALY_Z_THRESHOLD=2.0

# --- Correlation Engine ---
# CORRELATION_STRONG=0.7
# CORRELATION_MODERATE=0.4
# CORRELATION_MAX_LAG_DAYS=3

# --- AI Health Assistant (Phase 3) ---
# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=your_anthropic_key_here
# OPENAI_API_KEY=your_openai_key_here
# NCBI_API_KEY=your_ncbi_key_here
# NCBI_EMAIL=your_email@example.com
